# ── Box & Dice Website API ──────────────────────────────────────────────
# Generate a token in the CRM for your office group, then set it here.
# These are SECRET — set them in your host's Environment Variables
# (Cloudflare Pages / Vercel), NEVER in the code or a message.
#
# Auth sent as:  Authorization: Api-Key token=<BOXDICE_API_KEY>

BOXDICE_API_KEY=your-token-here

# The exact base URL Box & Dice give you with the key (confirm this — it can
# be account/region specific). Endpoints used: /sales_listings, /consultants,
# /enquiries
BOXDICE_API_BASE=https://api.boxdice.com.au/website/v1

# How often (seconds) listing pages re-fetch from the CRM. 600 = 10 minutes.
LISTINGS_REVALIDATE_SECONDS=600

# Leave true to run on the bundled sample listings.
# Set to false once the token + base URL above are working.
USE_MOCK_DATA=true

# Secret protecting the on-demand refresh webhook /api/revalidate
REVALIDATE_SECRET=choose-a-random-string
